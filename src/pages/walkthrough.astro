---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Walkthrough Día a Día" section="walkthrough" description="Walkthrough completo de Persona 3 Reload — guía día a día con seguimiento de progreso">

  <section class="page-hero">
    <p class="hero-eyebrow">Guía Completa · Día a Día</p>
    <h1 class="page-title"><span>Walkthrough</span> 100%</h1>
    <p class="page-subtitle">
      Cada acción, cada respuesta, cada decisión. Marcá lo que ya hiciste y seguí tu progreso.
      Basado en la guía de TenSquare3 (GameFAQs v2.5.0).
    </p>
  </section>

  <div class="content-wrap">

    <!-- PROGRESS BAR -->
    <div class="wt-progress-box">
      <div class="wt-progress-header">
        <span class="wt-progress-label">Progreso total</span>
        <span id="progress-text" class="wt-progress-count">0 / 0 completados</span>
      </div>
      <div class="wt-progress-track">
        <div id="progress-fill" class="wt-progress-fill" style="width:0%"></div>
      </div>

      <!-- AUTH ROW -->
      <div class="wt-auth-row">
        <!-- Estado: no logueado -->
        <div id="auth-signed-out" class="wt-auth-section">
          <button id="btn-google-signin" class="wt-btn wt-btn-google">
            <svg width="15" height="15" viewBox="0 0 24 24" style="flex-shrink:0;opacity:0.9"><path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Conectar con Google
          </button>
          <span class="wt-auth-hint">Sincronizá tu progreso entre dispositivos</span>
        </div>

        <!-- Estado: logueado -->
        <div id="auth-signed-in" class="wt-auth-section" style="display:none">
          <img id="auth-avatar" src="" alt="avatar" class="wt-auth-avatar">
          <div class="wt-auth-info">
            <span id="auth-name" class="wt-auth-name"></span>
            <span id="auth-sync-status" class="wt-auth-sync">Sincronizando...</span>
          </div>
          <button id="btn-signout" class="wt-btn wt-btn-sec" style="margin-left:auto">Salir</button>
        </div>
      </div>

      <div class="wt-save-btns">
        <button id="btn-export" class="wt-btn wt-btn-sec">⬇ Exportar JSON</button>
        <button id="btn-import-trigger" class="wt-btn wt-btn-sec">⬆ Importar JSON</button>
        <button id="btn-reset" class="wt-btn wt-btn-danger">✕ Reiniciar todo</button>
        <input type="file" id="btn-import" accept=".json" style="display:none">
      </div>
    </div>

    <!-- VIEW SWITCHER -->
    <div class="wt-view-switch">
      <button class="wt-view-btn active" id="btn-view-dia" onclick="switchView('dia')">✓ Día a Día</button>
      <button class="wt-view-btn" id="btn-view-resumen" onclick="switchView('resumen')">📅 Resumen Mensual</button>
      <button class="wt-view-btn" id="btn-view-clase" onclick="switchView('clase')">📖 Respuestas de Clase</button>
    </div>

    <!-- VISTA: RESPUESTAS DE CLASE -->
    <div id="view-clase" class="wt-view" style="display:none">
      <div class="section-label" style="margin-top:0">A lo largo del año escolar</div>
      <h2 class="section-title">Respuestas en Clase</h2>
      <p style="color:rgba(200,216,255,0.75);font-size:0.9rem;margin-bottom:1rem">
        Responder correctamente da <strong style="color:var(--gold)">Encanto +1</strong>. Los exámenes de julio y octubre dan bonos mayores.
        Con la respuesta correcta también pueden darte <strong>Académicos +1</strong> si quedás entre los mejores.
      </p>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Fecha</th><th>Pregunta / Contexto</th><th>Respuesta correcta</th></tr></thead>
          <tbody>
            <tr><td>4/8</td><td>Pregunta sobre los estandartes del Día del Niño</td><td><strong>"Vivid carp streamers"</strong></td></tr>
            <tr><td>4/27</td><td>Pregunta de opción múltiple</td><td><strong>"A"</strong></td></tr>
            <tr><td>5/6</td><td>Pregunta sobre Bullet Train</td><td><strong>"A pantograph"</strong></td></tr>
            <tr><td>5/13</td><td>Pregunta sobre péndulos</td><td><strong>"The Pendulum"</strong></td></tr>
            <tr><td>5/15</td><td>Pregunta sobre el mayo de 1968</td><td><strong>"May Blues"</strong></td></tr>
            <tr style="background:rgba(31,94,255,0.06)"><td colspan="3" style="color:var(--sky);font-weight:700;font-family:'Rajdhani',sans-serif">📝 EXÁMENES DE MAYO (18–22 de mayo)</td></tr>
            <tr><td>5/18</td><td>Examen — respuesta automática</td><td>—</td></tr>
            <tr><td>5/19</td><td>Examen parcial</td><td><strong>"May Blues"</strong></td></tr>
            <tr><td>5/20</td><td>Examen parcial</td><td><strong>"A Pendulum"</strong></td></tr>
            <tr><td>5/21</td><td>Examen parcial</td><td><strong>"Electricity"</strong></td></tr>
            <tr><td>5/22</td><td>Examen parcial</td><td><strong>"Jomon"</strong></td></tr>
            <tr><td>7/3</td><td>Pregunta sobre el período Heian</td><td><strong>"About Romance"</strong></td></tr>
            <tr style="background:rgba(31,94,255,0.06)"><td colspan="3" style="color:var(--sky);font-weight:700;font-family:'Rajdhani',sans-serif">📝 EXÁMENES DE JULIO (Mediados de julio)</td></tr>
            <tr><td>Día 1</td><td>Examen de julio</td><td><strong>"A Genius"</strong></td></tr>
            <tr><td>Día 2</td><td>Examen de julio</td><td><strong>"Synthesis"</strong></td></tr>
            <tr><td>Día 3</td><td>Examen de julio</td><td><strong>"Electromagnetic Waves"</strong></td></tr>
            <tr><td>Día 4</td><td>Examen de julio</td><td><strong>"Daydream"</strong></td></tr>
            <tr><td>Día 5</td><td>Examen de julio</td><td><strong>"Haiku"</strong></td></tr>
            <tr><td>9/17</td><td>Pregunta sobre la era Meiji</td><td><strong>"Era Meiji"</strong></td></tr>
            <tr><td>10/6</td><td>Pregunta sobre escritoras japonesas</td><td><strong>"Murasaki Shikibu"</strong></td></tr>
            <tr style="background:rgba(31,94,255,0.06)"><td colspan="3" style="color:var(--sky);font-weight:700;font-family:'Rajdhani',sans-serif">📝 EXÁMENES DE OCTUBRE (Finales)</td></tr>
            <tr><td>Día 1</td><td>Examen final</td><td><strong>"Waxing moon"</strong></td></tr>
            <tr><td>Día 2</td><td>Examen final</td><td><strong>"The Heike Story"</strong></td></tr>
            <tr><td>Día 3</td><td>Examen final</td><td><strong>"Atavistic"</strong></td></tr>
            <tr><td>Día 4</td><td>Examen final</td><td><strong>"Gloomy"</strong></td></tr>
            <tr><td>Día 5</td><td>Examen final</td><td><strong>"Dry"</strong></td></tr>
          </tbody>
        </table>
      </div>
      <div class="callout callout-tip">
        <strong>Tip:</strong> Las respuestas de clase también las podés ver en el Walkthrough día a día. Si quedás Top 3 en el examen, conseguís Encanto +2 extra.
      </div>
    </div>

    <!-- VISTA: RESUMEN MENSUAL -->
    <div id="view-resumen" class="wt-view" style="display:none">
      <div class="section-label" style="margin-top:0">Vista general · 10 meses</div>
      <h2 class="section-title">Resumen Mensual</h2>
      <div class="callout callout-warn">
        <strong>Regla de oro:</strong> Siempre chequeá el piso de Tartarus requerido antes de la luna llena del mes.
        Si no lo alcanzaste, la historia no avanza.
      </div>

      <div class="wt-cal-grid">
        <!-- ABRIL -->
        <div class="wt-cal-card">
          <div class="wt-cal-header" style="background:rgba(31,94,255,0.12)">
            <span class="wt-cal-month">🌑 ABRIL</span>
            <span class="wt-cal-badge">Sin jefe</span>
          </div>
          <div class="wt-cal-body">
            <div class="wt-cal-row"><span class="wt-cal-ico">🗼</span><span>Tartarus Bloque 1 — Thebel (1–22F)</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>4/8 — Primer día con clase, respuesta en clase</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>4/18 — Fool R1 desbloqueado (evening)</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>4/20 — Primera visita a Tartarus</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>4/22 — Tartarus 1–22F (sesión principal)</span></div>
            <div class="wt-cal-row wt-cal-prio"><span class="wt-cal-ico">⚠️</span><span>Abrí Hermit y Strength este mes</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">🎯</span><span>Meta: Encanto R2, Valentía R2, Chariot R3</span></div>
          </div>
        </div>

        <!-- MAYO -->
        <div class="wt-cal-card">
          <div class="wt-cal-header" style="background:rgba(46,255,158,0.08)">
            <span class="wt-cal-month">🌒 MAYO</span>
            <span class="wt-cal-badge badge-boss">Jefe: 9/5</span>
          </div>
          <div class="wt-cal-body">
            <div class="wt-cal-row"><span class="wt-cal-ico">🗼</span><span>Tartarus Bloque 2 (23–44F) — desbloqueado post-jefe</span></div>
            <div class="wt-cal-row wt-cal-boss"><span class="wt-cal-ico">🔴</span><span>5/9 — JEFE LUNA LLENA: Magician (noche)</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>5/10 — Elizabeth quests desbloqueados</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>5/11 — Hanged Man (Maiko) R1</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📝</span><span>Exámenes: 18–22 de mayo</span></div>
            <div class="wt-cal-row wt-cal-prio"><span class="wt-cal-ico">⚠️</span><span>Abrí Moon (Nozomi) el 5/30 — requiere Encanto R3</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">🎯</span><span>Meta: Encanto R4, Académicos R3, Valentía R3</span></div>
          </div>
        </div>

        <!-- JUNIO -->
        <div class="wt-cal-card">
          <div class="wt-cal-header" style="background:rgba(31,94,255,0.12)">
            <span class="wt-cal-month">🌓 JUNIO</span>
            <span class="wt-cal-badge badge-boss">Jefe: 8/6</span>
          </div>
          <div class="wt-cal-body">
            <div class="wt-cal-row"><span class="wt-cal-ico">🗼</span><span>Tartarus Bloque 3 (45–69F)</span></div>
            <div class="wt-cal-row wt-cal-boss"><span class="wt-cal-ico">🔴</span><span>6/8 — JEFE: Empress & Emperor (R3 y R4)</span></div>
            <div class="wt-cal-row wt-cal-prio"><span class="wt-cal-ico">⚠️</span><span>Maiko (Hanged) — solo disponible JUN–AGO</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">🔗</span><span>Emperor R10 posible este mes si priorizás</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">🎯</span><span>Meta: Emperor R5+, Magician R6, Hierophant R5</span></div>
          </div>
        </div>

        <!-- JULIO -->
        <div class="wt-cal-card">
          <div class="wt-cal-header" style="background:rgba(255,209,102,0.08)">
            <span class="wt-cal-month">🌕 JULIO</span>
            <span class="wt-cal-badge">Vacaciones</span>
          </div>
          <div class="wt-cal-body">
            <div class="wt-cal-row"><span class="wt-cal-ico">🗼</span><span>Tartarus Bloque 4 (70–109F)</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">🔗</span><span>7/1 — Emperor R10 ✅</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📝</span><span>Exámenes parciales — mediados de julio</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>7/25 — Inicio de vacaciones (SLs del colegio off)</span></div>
            <div class="wt-cal-row wt-cal-prio"><span class="wt-cal-ico">⚠️</span><span>Piso 71F requerido antes del 7/7</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">🎯</span><span>Meta: Justice R5, Hermit R7, Priestess R1</span></div>
          </div>
        </div>

        <!-- AGOSTO -->
        <div class="wt-cal-card">
          <div class="wt-cal-header" style="background:rgba(255,58,92,0.06)">
            <span class="wt-cal-month">🌖 AGOSTO</span>
            <span class="wt-cal-badge badge-boss">Jefe: 6/8</span>
          </div>
          <div class="wt-cal-body">
            <div class="wt-cal-row wt-cal-boss"><span class="wt-cal-ico">🔴</span><span>8/6 — JEFE: Chariot & Justice</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>8/7–13 — Campamento escolar (solo historia)</span></div>
            <div class="wt-cal-row wt-cal-prio"><span class="wt-cal-ico">⚠️</span><span>Maiko (Hanged) DEBE terminarse antes del 8/31</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">🎯</span><span>Meta: Hanged R10 ✅, Hermit R10 ✅</span></div>
          </div>
        </div>

        <!-- SEPTIEMBRE -->
        <div class="wt-cal-card">
          <div class="wt-cal-header" style="background:rgba(31,94,255,0.12)">
            <span class="wt-cal-month">🌗 SEP</span>
            <span class="wt-cal-badge badge-boss">Jefe: 22/9</span>
          </div>
          <div class="wt-cal-body">
            <div class="wt-cal-row"><span class="wt-cal-ico">🗼</span><span>Tartarus Bloque 5 (110–146F) — objetivo 107F</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>9/2 — Aigis se une (Aeon SL disponible)</span></div>
            <div class="wt-cal-row wt-cal-boss"><span class="wt-cal-ico">🔴</span><span>9/22 — JEFE: Hermit</span></div>
            <div class="wt-cal-row wt-cal-prio"><span class="wt-cal-ico">⚠️</span><span>Mitsuru SL — AHORA O NUNCA (requiere Encanto R4)</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">🎯</span><span>Meta: Empress R1, Aeon R2, Moon R3</span></div>
          </div>
        </div>

        <!-- OCTUBRE -->
        <div class="wt-cal-card">
          <div class="wt-cal-header" style="background:rgba(255,209,102,0.08)">
            <span class="wt-cal-month">🌘 OCTUBRE</span>
            <span class="wt-cal-badge badge-boss">Jefe: 4/10</span>
          </div>
          <div class="wt-cal-body">
            <div class="wt-cal-row"><span class="wt-cal-ico">🗼</span><span>Tartarus Bloque 6 (147–183F) — objetivo 145F</span></div>
            <div class="wt-cal-row wt-cal-boss"><span class="wt-cal-ico">🔴</span><span>10/4 — JEFE: Fortune</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📝</span><span>Exámenes finales — 19–23 de octubre</span></div>
            <div class="wt-cal-row wt-cal-prio"><span class="wt-cal-ico">⚠️</span><span>Sprint SLs: Mitsuru, Aigis, Akihiko este mes</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">🎯</span><span>Meta: Empress R5, Aeon R5, Strength R8</span></div>
          </div>
        </div>

        <!-- NOVIEMBRE -->
        <div class="wt-cal-card">
          <div class="wt-cal-header" style="background:rgba(255,58,92,0.06)">
            <span class="wt-cal-month">🌑 NOVIEMBRE</span>
            <span class="wt-cal-badge badge-boss">Jefe: 3/11</span>
          </div>
          <div class="wt-cal-body">
            <div class="wt-cal-row"><span class="wt-cal-ico">🗼</span><span>Tartarus Bloque 7 (184–226F) — objetivo 172F</span></div>
            <div class="wt-cal-row wt-cal-boss"><span class="wt-cal-ico">🔴</span><span>11/3 — JEFE: Tower (Carols of the Moon)</span></div>
            <div class="wt-cal-row wt-cal-prio"><span class="wt-cal-ico">⚠️</span><span>CERRÁ todos los SLs que puedas — el tiempo se acaba</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">🎯</span><span>Meta: Empress R10, Aeon R8, Aigis R8</span></div>
          </div>
        </div>

        <!-- DICIEMBRE -->
        <div class="wt-cal-card">
          <div class="wt-cal-header" style="background:rgba(200,216,255,0.06)">
            <span class="wt-cal-month">🌕 DICIEMBRE</span>
            <span class="wt-cal-badge badge-boss">Jefe: 2/12</span>
          </div>
          <div class="wt-cal-body">
            <div class="wt-cal-row wt-cal-boss"><span class="wt-cal-ico">🔴</span><span>12/2 — JEFE TRIPLE: Star, Moon, Sun</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>12/5 — Decisión importante de historia</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>12/24 — Navidad (escena si tenés SL romántico R10)</span></div>
            <div class="wt-cal-row wt-cal-prio"><span class="wt-cal-ico">⚠️</span><span>SLs que queden sin terminar — última oportunidad</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">🎯</span><span>Meta: Todos los SLs activos a R10</span></div>
          </div>
        </div>

        <!-- ENERO -->
        <div class="wt-cal-card">
          <div class="wt-cal-header" style="background:rgba(31,94,255,0.15)">
            <span class="wt-cal-month">🌑 ENERO</span>
            <span class="wt-cal-badge badge-boss">Jefe Final</span>
          </div>
          <div class="wt-cal-body">
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>1/1–20 — Últimas actividades y encargos</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">📅</span><span>1/30 — Preparación para el jefe final</span></div>
            <div class="wt-cal-row wt-cal-boss"><span class="wt-cal-ico">🔴</span><span>1/31 — JEFE FINAL: Nyx (14 fases)</span></div>
            <div class="wt-cal-row"><span class="wt-cal-ico">🎯</span><span>Nivel recomendado: 70–75+, Equipo: 65+</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- VISTA: DÍA A DÍA -->
    <div id="view-dia" class="wt-view">
    <!-- MONTH NAV TABS -->
    <nav class="month-tabs" id="month-tabs">
      <a href="#abril" class="month-tab active">ABR</a>
      <a href="#mayo" class="month-tab">MAY</a>
      <a href="#junio" class="month-tab">JUN</a>
      <a href="#julio" class="month-tab">JUL</a>
      <a href="#agosto" class="month-tab">AGO</a>
      <a href="#septiembre" class="month-tab">SEP</a>
      <a href="#octubre" class="month-tab">OCT</a>
      <a href="#noviembre" class="month-tab">NOV</a>
      <a href="#diciembre" class="month-tab">DIC</a>
      <a href="#enero" class="month-tab">ENE</a>
    </nav>

    <!-- WALKTHROUGH CONTENT -->
    <div id="walkthrough-content"></div>
    </div>

  </div>

  <style is:global>
    /* ---- PROGRESS BOX ---- */
    .wt-progress-box {
      background: var(--deep); border: 1px solid rgba(31,94,255,0.25);
      border-radius: 10px; padding: 1.25rem 1.5rem; margin-bottom: 2rem;
    }
    .wt-progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem; }
    .wt-progress-label { font-family: 'Rajdhani', sans-serif; font-weight: 700; color: var(--sky); }
    .wt-progress-count { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--moon); }
    .wt-progress-track { height: 8px; background: rgba(31,94,255,0.15); border-radius: 4px; overflow: hidden; margin-bottom: 1rem; }
    .wt-progress-fill { height: 100%; background: linear-gradient(90deg, var(--azure), var(--green)); border-radius: 4px; transition: width 0.4s ease; }
    .wt-save-btns { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .wt-btn { font-family: 'Rajdhani', sans-serif; font-size: 0.85rem; font-weight: 600; padding: 0.35rem 0.9rem; border-radius: 4px; border: 1px solid; cursor: pointer; transition: all 0.2s; }
    .wt-btn-sec { background: rgba(31,94,255,0.1); border-color: rgba(31,94,255,0.3); color: var(--sky); }
    .wt-btn-sec:hover { background: rgba(31,94,255,0.2); border-color: var(--azure); }
    .wt-btn-danger { background: rgba(255,58,92,0.08); border-color: rgba(255,58,92,0.3); color: var(--red); }
    .wt-btn-danger:hover { background: rgba(255,58,92,0.18); }

    /* ---- MONTH TABS ---- */
    .month-tabs { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 2rem; }
    .month-tab {
      font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; font-weight: 600;
      padding: 0.35rem 0.7rem; border-radius: 4px; text-decoration: none;
      background: rgba(31,94,255,0.08); border: 1px solid rgba(31,94,255,0.2);
      color: var(--moon); transition: all 0.2s; position: relative;
    }

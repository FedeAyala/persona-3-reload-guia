    // =============================================
    // PROGRESS STATE
    // =============================================
    const STORAGE_KEY = 'p3r_walkthrough_v1';
    let checked = new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'));

    function save() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify([...checked]));
      updateProgress();
      // Si Firebase está listo y hay usuario logueado, sincroniza a la nube
      (window as any)._scheduleCloudSave?.();
    }

    // =============================================
    // RENDER
    // =============================================
    function buildCheckId(monthKey, dayId, slotIdx, itemIdx) {
      return `${monthKey}-${dayId}-${slotIdx}-${itemIdx}`;
    }

    function renderItem(id, text) {
      const isDone = checked.has(id);
      return `<label class="wt-check-item ${isDone ? 'checked' : ''}" data-id="${id}">
        <input type="checkbox" ${isDone ? 'checked' : ''}>
        <span class="wt-checkmark"></span>
        <span class="wt-check-text">${text}</span>
      </label>`;
    }

    function countDayItems(monthKey, day) {
      if (day.isChecklist) return 0;
      let total = 0, done = 0;
      day.slots.forEach((slot, si) => {
        slot.items.forEach((item, ii) => {
          total++;
          if (checked.has(buildCheckId(monthKey, day.id, si, ii))) done++;
        });
      });
      return { total, done };
    }

    function renderChecklist(day) {
      const cl = day.checklist;
      return `<div class="wt-eom">
        <h4>📋 Checklist de fin de mes</h4>
        <div class="wt-eom-grid">
          ${cl.stats.map(s => `<div class="wt-eom-item"><span style="color:var(--gold)">📊</span> ${s}</div>`).join('')}
          ${cl.sl.map(s => `<div class="wt-eom-item"><span style="color:var(--green)">🔗</span> <strong>${s}</strong></div>`).join('')}
          ${(cl.trophies||[]).map(t => `<div class="wt-eom-item"><span style="color:var(--gold)">🏆</span> ${t}</div>`).join('')}
        </div>
      </div>`;
    }

    function renderDay(monthKey, day, idx) {
      if (day.isChecklist) return renderChecklist(day);
      const { total, done } = countDayItems(monthKey, day);
      const allDone = total > 0 && done === total;
      return `<div class="wt-day ${allDone ? 'all-done' : ''}" id="day-${day.id}">
        <div class="wt-day-header" onclick="toggleDay(this)">
          <span class="wt-day-date">${day.date}</span>
          <span class="wt-day-title">${day.name}</span>
          <span class="wt-day-check">✓</span>
          <span class="wt-day-mini-prog" data-day-id="${day.id}" data-month="${monthKey}">${done}/${total}</span>
          <span class="wt-day-toggle">›</span>
        </div>
        <div class="wt-day-body">
          ${day.slots.map((slot, si) => `
            <div class="wt-slot">
              <div class="wt-slot-label">${slot.label}</div>
              ${slot.items.map((item, ii) => renderItem(buildCheckId(monthKey, day.id, si, ii), item.text)).join('')}
            </div>
          `).join('')}
        </div>
      </div>`;
    }

    function renderMonth(monthKey, monthData) {
      const totalItems = monthData.days.reduce((acc, d) => {
        if (d.isChecklist) return acc;
        return acc + d.slots.reduce((a, s) => a + s.items.length, 0);
      }, 0);
      const doneItems = monthData.days.reduce((acc, d) => {
        if (d.isChecklist) return acc;
        return acc + d.slots.reduce((a, s, si) => a + s.items.filter((_, ii) => checked.has(buildCheckId(monthKey, d.id, si, ii))).length, 0);
      }, 0);
      const pct = totalItems ? Math.round(doneItems / totalItems * 100) : 0;

      return `<div class="wt-month" id="${monthKey}">
        <div class="wt-month-header">
          <span>${monthData.title}</span>
          <span class="wt-month-pct" data-month-pct="${monthKey}">${pct}% (${doneItems}/${totalItems})</span>
        </div>
        ${monthData.days.map((d, idx) => renderDay(monthKey, d, idx)).join('')}
      </div>`;
    }

    function render() {
      const container = document.getElementById('walkthrough-content');
      container.innerHTML = Object.entries(W).map(([k, v]) => renderMonth(k, v)).join('');
      attachListeners();
      updateProgress();
    }

    function attachListeners() {
      document.querySelectorAll('.wt-check-item').forEach(label => {
        label.addEventListener('click', (e) => {
          e.preventDefault();
          const id = label.dataset.id;
          if (checked.has(id)) checked.delete(id);
          else checked.add(id);
          label.classList.toggle('checked', checked.has(id));
          save();
          updateDayState(label);
        });
      });
    }

    function updateDayState(label) {
      const dayEl = label.closest('.wt-day');
      if (!dayEl) return;
      const all = dayEl.querySelectorAll('.wt-check-item');
      const done = dayEl.querySelectorAll('.wt-check-item.checked');
      dayEl.classList.toggle('all-done', all.length > 0 && all.length === done.length);
      const miniProg = dayEl.querySelector('[data-day-id]');
      if (miniProg) {
        const mk = miniProg.dataset.month, di = miniProg.dataset.dayId;
        miniProg.textContent = `${done.length}/${all.length}`;
      }
      updateMonthPct(dayEl.closest('.wt-month'));
    }

    function updateMonthPct(monthEl) {
      if (!monthEl) return;
      const all = monthEl.querySelectorAll('.wt-check-item');
      const done = monthEl.querySelectorAll('.wt-check-item.checked');
      const pct = all.length ? Math.round(done.length / all.length * 100) : 0;
      const key = monthEl.id;
      const pctEl = monthEl.querySelector(`[data-month-pct="${key}"]`);
      if (pctEl) pctEl.textContent = `${pct}% (${done.length}/${all.length})`;
      // update tab
      const tab = document.querySelector(`.month-tab[href="#${key}"]`);
      if (tab) {
        tab.classList.toggle('done', pct === 100);
        tab.classList.toggle('in-progress', pct > 0 && pct < 100);
      }
    }

    function updateProgress() {
      const all = document.querySelectorAll('.wt-check-item');
      const done = document.querySelectorAll('.wt-check-item.checked');
      const pct = all.length ? Math.round(done.length / all.length * 100) : 0;
      const fill = document.getElementById('progress-fill');
      const txt = document.getElementById('progress-text');
      if (fill) fill.style.width = pct + '%';
      if (txt) txt.textContent = `${done.length} / ${all.length} completados (${pct}%)`;
      document.querySelectorAll('.wt-month').forEach(m => updateMonthPct(m));
    }

    function toggleDay(header: HTMLElement) {
      header.closest('.wt-day')?.classList.toggle('open');
    }
    (window as any).toggleDay = toggleDay;

    // =============================================
    // VIEW SWITCHER
    // =============================================
    function switchView(view: string) {
      ['dia','resumen','clase'].forEach(v => {
        const el = document.getElementById('view-' + v);
        const btn = document.getElementById('btn-view-' + v);
        if (el) el.style.display = v === view ? '' : 'none';
        if (btn) btn.classList.toggle('active', v === view);
      });
    }
    (window as any).switchView = switchView;

    // =============================================
    // EXPORT / IMPORT / RESET
    // =============================================
    document.getElementById('btn-export')?.addEventListener('click', () => {
      const data = JSON.stringify({ version: 1, checked: [...checked], date: new Date().toISOString() }, null, 2);
      const blob = new Blob([data], { type: 'application/json' });
      const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
      a.download = `p3r-progreso-${new Date().toISOString().slice(0,10)}.json`;
      a.click();
    });

    document.getElementById('btn-import-trigger')?.addEventListener('click', () => {
      (document.getElementById('btn-import') as HTMLInputElement)?.click();
    });

    (document.getElementById('btn-import') as HTMLInputElement)?.addEventListener('change', (e) => {
      const input = e.target as HTMLInputElement;
      const file = input?.files?.[0]; if (!file) return;
      const reader = new FileReader();
      reader.onload = (ev) => {
        try {
          const result = (ev.target as FileReader)?.result;
          if (typeof result !== 'string') return;
          const data = JSON.parse(result);
          if (data.checked) {
            checked = new Set(data.checked);
            save();
            render();
            alert('✅ Progreso importado correctamente.');
          }
        } catch { alert('❌ Error al leer el archivo. Aseguráte de que sea un JSON válido.'); }
      };
      reader.readAsText(file);
      input.value = '';
    });

    document.getElementById('btn-reset')?.addEventListener('click', () => {
      if (confirm('¿Estás seguro? Esto borra TODO tu progreso guardado.')) {
        checked = new Set();
        save();
        render();
      }
    });

    // =============================================
    // FIREBASE AUTH + FIRESTORE (browser-only, diferido)
    // =============================================
    document.addEventListener('DOMContentLoaded', () => {
      const firebaseConfig = {
        apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
        authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
        projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
        storageBucket: import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
        messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
        appId: import.meta.env.PUBLIC_FIREBASE_APP_ID
      };

      const app = initializeApp(firebaseConfig);
      const auth = getAuth(app);
      const db = getFirestore(app);

      let currentUser: any = null;
      let syncTimeout: ReturnType<typeof setTimeout> | null = null;

      function setSyncStatus(msg: string) {
        const el = document.getElementById('auth-sync-status');
        if (el) el.textContent = msg;
      }

      async function saveToFirestore() {
        if (!currentUser) return;
        setSyncStatus('Guardando...');
        try {
          await setDoc(doc(db, 'progress', currentUser.uid), {
            checked: [...checked],
            updatedAt: new Date().toISOString()
          });
          setSyncStatus('✓ Guardado en la nube');
        } catch (e) {
          setSyncStatus('Error al guardar');
          console.error(e);
        }
      }

      // Expone el debounce para que save() lo pueda llamar
      (window as any)._scheduleCloudSave = () => {
        if (!currentUser) return;
        if (syncTimeout) clearTimeout(syncTimeout);
        syncTimeout = setTimeout(saveToFirestore, 1500);
      };

      async function loadFromFirestore(uid: string) {
        setSyncStatus('Cargando progreso...');
        try {
          const snap = await getDoc(doc(db, 'progress', uid));
          if (snap.exists()) {
            const cloud: string[] = snap.data().checked ?? [];
            cloud.forEach((id: string) => checked.add(id));
            save();
            render();
          }
          setSyncStatus('✓ Sincronizado');
        } catch (e) {
          setSyncStatus('Error al cargar');
          console.error(e);
        }
      }

      onAuthStateChanged(auth, async (user) => {
        const signedOut = document.getElementById('auth-signed-out');
        const signedIn  = document.getElementById('auth-signed-in');
        const avatar    = document.getElementById('auth-avatar') as HTMLImageElement;
        const nameEl    = document.getElementById('auth-name');

        if (user) {
          currentUser = user;
          if (signedOut) signedOut.style.display = 'none';
          if (signedIn)  signedIn.style.display  = 'flex';
          if (avatar && user.photoURL) avatar.src = user.photoURL;
          if (nameEl) nameEl.textContent = user.displayName ?? user.email ?? '';
          await loadFromFirestore(user.uid);
        } else {
          currentUser = null;
          if (signedOut) signedOut.style.display = 'flex';
          if (signedIn)  signedIn.style.display  = 'none';
        }
      });

      document.getElementById('btn-google-signin')?.addEventListener('click', async () => {
        try {
          await signInWithPopup(auth, new GoogleAuthProvider());
        } catch (e: any) {
          if (e.code !== 'auth/popup-closed-by-user') alert('Error al iniciar sesión: ' + e.message);
        }
      });

      document.getElementById('btn-signout')?.addEventListener('click', async () => {
        if (confirm('¿Cerrar sesión? Tu progreso queda guardado localmente.')) {
          await signOut(auth);
        }
      });
    }); // fin DOMContentLoaded

    // =============================================
    // INIT
    // =============================================
    render();
  </script>

